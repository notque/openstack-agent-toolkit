{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 plugins/sapcc/hooks/destructive-action-gate.py",
        "timeout": 3000,
        "matcher": "mcp__*"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 plugins/sapcc/hooks/credential-expiry-detector.py",
        "timeout": 3000,
        "matcher": "mcp__*"
      }
    ]
  }
}
